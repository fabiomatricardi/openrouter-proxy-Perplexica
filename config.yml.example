# Server settings
server:
  host: "0.0.0.0"
  port: 5555
  access_key: "your_local_access_key_here"
  log_level: "INFO"
  http_log_level: "INFO"

# OpenRouter API keys
openrouter:
  request_delay: 15  # 🔑 NEW: Delay before forwarding (seconds)
  keys:
    - "sk-or-v1-xxxxxx"  # API key from first account
    - "sk-or-v1-xxxxxx"  # API key from second  account
  key_selection_strategy: "round-robin"
  key_selection_opts: []
  base_url: "https://openrouter.ai/api/v1"
  public_endpoints:
    - "/api/v1/models"
  rate_limit_cooldown: 14400
  free_only: false
  global_rate_delay: 0

# Vane integration settings
vane:
  # Accept requests with this model name and bearer token
  local_model_name: "openrouter"
  local_bearer_token: "openrouter"
  
  # List of free OpenRouter models to rotate through (user-configurable) all models must end with ":free"
  free_models:
    - "nvidia/nemotron-3-super-120b-a12b:free"
    - "nvidia/nemotron-3-nano-30b-a3b:free"
    - "z-ai/glm-4.5-air:free"
  
  # Model selection strategy: round-robin | random
  model_selection: "round-robin"
  
  # Enable streaming passthrough (preserve SSE from OpenRouter)
  enable_streaming: true

# Proxy settings for outgoing requests to OpenRouter
requestProxy:
  enabled: false
  url: "socks5://username:password@example.com:1080"
