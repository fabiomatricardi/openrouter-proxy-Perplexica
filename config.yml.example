# Server settings
server:
  host: "0.0.0.0"
  port: 5555
  access_key: "your_local_access_key_here"
  log_level: "INFO"
  http_log_level: "INFO"

# OpenRouter API keys
openrouter:
  keys:
    - "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"
    - "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"
  key_selection_strategy: "round-robin"
  key_selection_opts: []
  base_url: "https://openrouter.ai/api/v1"
  public_endpoints:
    - "/api/v1/models"
  rate_limit_cooldown: 14400
  free_only: false
  global_rate_delay: 0

# Vane integration settings
vane:
  # Accept requests with this model name and bearer token
  local_model_name: "openrouter"
  local_bearer_token: "openrouter"
  
  # List of free OpenRouter models to rotate through (user-configurable)
  free_models:
    - "google/gemma-3-1b-it:free"
    - "meta-llama/llama-3.2-1b-instruct:free"
    - "qwen/qwen-2.5-7b-instruct:free"
  
  # Model selection strategy: round-robin | random
  model_selection: "round-robin"
  
  # Enable streaming passthrough (preserve SSE from OpenRouter)
  enable_streaming: true

# Proxy settings for outgoing requests to OpenRouter
requestProxy:
  enabled: false
  url: "socks5://username:password@example.com:1080"